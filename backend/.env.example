# Grok AI (X.AI) - Replace OpenAI
GROK_API_KEY=your_grok_api_key_here

# Sarvam TTS (if using)
SARVAM_API_KEY=your_sarvam_api_key_here

# Remove these OpenAI keys - no longer needed
# OPENAI_API_KEY=not_needed_anymore