# Database
DATABASE_URL=sqlite:///./hireflow.db

# JWT Authentication
JWT_SECRET_KEY=your_jwt_secret_key_here

# Cloudinary (for file uploads)
CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
